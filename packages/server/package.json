{
  "name": "argusai-server",
  "version": "0.6.1",
  "type": "module",
  "description": "ArgusAI Server — centralized service layer for team-wide test result aggregation, sync, and notifications",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffkit/argusai.git",
    "directory": "packages/server"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "argusai-core": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0",
    "mysql2": "^3.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
